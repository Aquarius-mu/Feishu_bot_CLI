{
  "schema": "2.0",
  "config": { "wide_screen_mode": true },
  "header": {
    "title": { "tag": "plain_text", "content": "📋 Morning Briefing | {{date}}" },
    "template": "blue",
    "icon": { "tag": "standard_icon", "token": "calendar-outlined", "color": "blue" }
  },
  "body": {
    "elements": [
      {
        "tag": "collapsible_panel",
        "expanded": true,
        "header": {
          "title": { "tag": "plain_text", "content": ":WAITING: 异常 & 关注点" },
          "background_color": "orange-100"
        },
        "elements": [
          {
            "tag": "div",
            "text": { "tag": "lark_md", "content": "{{anomalies_section}}" }
          }
        ]
      },
      { "tag": "hr" },
      {
        "tag": "collapsible_panel",
        "expanded": true,
        "header": {
          "title": { "tag": "plain_text", "content": ":DONE: 今日 Action Queue" },
          "background_color": "blue-100"
        },
        "elements": [
          {
            "tag": "div",
            "text": { "tag": "lark_md", "content": "{{actions_list}}" }
          }
        ]
      },
      { "tag": "hr" },
      {
        "tag": "button",
        "text": { "tag": "plain_text", "content": "✅ Confirm & Execute" },
        "type": "primary",
        "behaviors": [{ "type": "callback", "value": { "action": "confirm_today", "date": "{{date}}" } }]
      },
      {
        "tag": "button",
        "text": { "tag": "plain_text", "content": "🔧 Adjust Priorities" },
        "type": "default",
        "behaviors": [{ "type": "callback", "value": { "action": "adjust_priority", "date": "{{date}}" } }]
      },
      {
        "tag": "button",
        "text": { "tag": "plain_text", "content": "+ Add Task" },
        "type": "default",
        "behaviors": [{ "type": "callback", "value": { "action": "add_task", "date": "{{date}}" } }]
      },
      { "tag": "hr" },
      {
        "tag": "div",
        "text": { "tag": "lark_md", "content": "<font color=grey>:PROCESSING: Generated at {{timestamp}} | Auto-synced to Bitable | Reply 确认 / 调整 / 加任务</font>" }
      }
    ]
  }
}
